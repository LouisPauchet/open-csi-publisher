# Copy this to a gitignored env file of your own — e.g. local/.env — and fill in real
# values. Do NOT copy it to a root-level `.env`: pydantic-settings reads that file
# unconditionally for every Settings() construction, including the test suite's, so a
# customized SOURCES_FILE there silently breaks tests that expect the default sample
# dataset set. Load a local override explicitly, scoped to one invocation, via uv's own
# --env-file flag instead:
#
#   uv run --env-file local/.env uvicorn open_csi_publisher.api.app:create_app --factory --reload
#
# See docs/running_locally.md for the full list of variables and their defaults.

# --- Core ---
# DATABASE_URL=sqlite:///./local/state.db
# SOURCES_FILE=local/sources.yaml
# BRANDING_FILE=sample_configs/branding.yaml
# BASE_DIR=.

# --- OIDC / Entra ID (unset, or partially set = every caller anonymous) ---
# All four values below must be set for login to be enabled; a partially
# configured setup degrades to anonymous-only (logged as an error), not a crash.
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# SESSION_SECRET_KEY=

# --- Publish endpoint ---
# PUBLISH_API_KEYS_RAW=
# PUBLISH_CACHE_DIR=local/publish_cache

# --- ThingsBoard ---
# Shared across every ThingsBoard tenant/prefix, not per-instance.
# THINGSBOARD_DISCOVERY_INTERVAL_SECONDS=3600

# One block per `thingsboard` sources.yaml entry, named after that entry's own
# credentials_env_prefix (defaults to THINGSBOARD if the entry doesn't set one).
# Example matching the two commented-out entries in sample_configs/sources.yaml:

# THINGSBOARD_SVALBARD_BASE_URL=https://svalbard.example.com
# THINGSBOARD_SVALBARD_USERNAME=
# THINGSBOARD_SVALBARD_PASSWORD=

# THINGSBOARD_NY_ALESUND_BASE_URL=https://ny-alesund.example.com
# THINGSBOARD_NY_ALESUND_USERNAME=
# THINGSBOARD_NY_ALESUND_PASSWORD=
